# General Settings
ENV=production
LOG_LEVEL=INFO

# Database Configuration (Real infra ready)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=traffic_db
DATABASE_URL=postgresql://postgres:postgres@db:5432/traffic_db

# Message Queue (Real infra ready)
REDIS_URL=redis://redis:6379/0

# Object Storage (Still locally mocked via file paths)
STORAGE_LOCAL_PATH=./object_storage

# Domain Specific Thresholds
HELMET_CONFIDENCE_THRESHOLD=0.65
ANPR_OCR_THRESHOLD=0.75
