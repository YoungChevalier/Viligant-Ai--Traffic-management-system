# General Settings
ENV=production
LOG_LEVEL=INFO

# Database Configuration
# Use local SQLite for development: sqlite:///./dashboard.sqlite
# Use PostgreSQL for production: postgresql://user:password@host/dbname
DATABASE_URL=sqlite:///./dashboard.sqlite

# Security & Authentication
# Generate a secure random string for JWT_SECRET (e.g., openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS & Frontend Integration
# In development: http://localhost:8080 (or wherever frontend is served)
# In production: https://your-vercel-app.vercel.app
CORS_ORIGIN=*

# Server Port (auto-assigned by Render/Railway)
PORT=8000

# Object Storage (Still locally mocked via file paths)
STORAGE_LOCAL_PATH=./object_storage

# Domain Specific Thresholds
HELMET_CONFIDENCE_THRESHOLD=0.65
ANPR_OCR_THRESHOLD=0.75
